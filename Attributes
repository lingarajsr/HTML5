<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML Attributes Example</title>
</head>
<body>

<h1 id="mainHeading" class="title">Main Heading</h1>

<p style="color: blue;" title="This is a paragraph">
    This is a paragraph with style and title attributes.
</p>

<a href="https://www.google.com" target="_blank" title="Go to Google">
    Visit Google
</a>

<ul type="square">
    <li>HTML</li>
    <li>CSS</li>
    <li>JavaScript</li>
</ul>

<img src="https://via.placeholder.com/150" alt="Sample Image" width="150" height="150">

<form action="#" method="post">
    <label for="username">Enter Name:</label>
    <input type="text" id="username" name="username" placeholder="Your Name" required>
    <button type="submit" disabled>Submit</button>
</form>

</body>
</html>
