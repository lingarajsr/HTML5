<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML5 Structure Example</title>
</head>
<body>

<header>
    <h1>My Website</h1>
</header>

<nav>
    <a href="#">Home</a> |
    <a href="#">About</a> |
    <a href="#">Contact</a>
</nav>

<section>
    <h2>Welcome</h2>
    <p>This is a simple HTML5 page structure.</p>
</section>

<article>
    <h3>Article Title</h3>
    <p>This is an example of an article section.</p>
</article>

<aside>
    <p>This is sidebar content.</p>
</aside>

<footer>
    <p>&copy; 2026 My Website</p>
</footer>

</body>
</html>
